# AgentOS - Developer API Keys Template
# Rename this file to .env and fill in the keys you want to use.
# NEVER commit the actual .env file or push your keys to public repositories.

# Model API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Local Model Settings
OLLAMA_API_BASE=http://localhost:11434

# Kernel Port Configuration
AGENTOS_PORT=8080
AGENTOS_ENV=development
